@page "/"
@using MathProject.Models
@inject FirebaseService FirebaseService

<PageTitle>פרויקטים</PageTitle>



<div class="container">
    <div class="header-section">
        <h1 class="d-inline-flex align-items-center gap-3">
            מרכז הלמידה של י1 התותחים
            <i class="bi bi-trophy-fill"></i>
        </h1>
        <div class="header-accent"></div>
    </div>
    <div class="status-projects">
        <StatusProjects Projects="projects" />
    </div>
    <div class="main-grid">
        @foreach (var p in projects)
        {
            <ProjectCard @key="p.Id" Project="p" OnDataChanged="StateHasChanged"/>
        }
    </div>
</div>

@code {

    private List<ProjectModel> projects;

    protected override async Task OnInitializedAsync()
    {
        // זו השורה שמושכת את הכל מהענן
        projects = await FirebaseService.GetProjectsAsync();
    }
}