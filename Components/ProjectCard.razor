@using MathProject.Models;
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject FirebaseService FirebaseService

<div class="project-card">
    <h3>@Project.Topic</h3>
    <p class="students">מוגש ע"י: @Project.Students</p>

    @* סטטוס כללי של הפרויקט *@
    @if(string.IsNullOrEmpty(Project.PresentationLink) &&
            string.IsNullOrEmpty(Project.VideoLink) &&
            string.IsNullOrEmpty(Project.ExercisesLink)) {
    <div class="status.missing)">
        <i class="bi bi-hourglass-split"></i>
        הגיע הזמן להתחיל לעבוד
    </div>
            }
    <div class="status @(IsComplete() ? "done" : "working")">
        <i class="bi @(IsComplete() ? "bi-check-circle-fill" : "bi-hourglass-split")"></i>
        @(IsComplete() ? "מוכן ללמידה" : "בעבודה")
    </div>

    <div class="links-container">
        @* כפתור מצגת *@
        <div class="edit-wrapper">
            <a href="@Project.PresentationLink"
               target="_blank"
               class="custom-btn btn-pres @(string.IsNullOrEmpty(Project.PresentationLink) ? "disabled" : "active")"
                <i class="bi bi-file-easel"></i>
                <span>מצגת לימודית</span>
                @if (string.IsNullOrEmpty(Project.PresentationLink))
                {<span class="badge">טרם הועלה</span>}
            </a>
            <button class="edit-icon-btn" @onclick="ToggleEditPres">
                <i class="bi bi-pencil"></i>
            </button>
        </div>
        @if (showEditPres)
        {
            <div class="edit-box">
                <input @bind="tempPresentationLink" placeholder="הדבק לינק למצגת..."/>
                <button @onclick='() => OnLinkUpdate(tempPresentationLink,
                                  () => showEditPres = false,
                                  () => Project.PresentationLink = tempPresentationLink)'>
                    שמור
                </button>
            </div>
            @if (showAlert)
            {
                <div class="alert alert-danger" role="alert">
                    הקישור שהזנת אינו תקין.
                </div>
            }
        }


        @* כפתור סרטון *@
        <div class="edit-wrapper">
            <a href="@Project.VideoLink" target="_blank"
               class="custom-btn btn-video @(string.IsNullOrEmpty(Project.VideoLink) ? "disabled" : "active")">
                <i class="bi bi-play-btn"></i>
                <span>סרטון הסבר</span>
                @if (string.IsNullOrEmpty(Project.VideoLink))
                {<span class="badge">טרם הועלה</span>}
            </a>
            <button class="edit-icon-btn" @onclick="ToggleVideoPres">
                <i class="bi bi-pencil"></i>
            </button>
        </div>
        @if (showEditVideo)
        {
            <div class="edit-box">
                <input @bind="tempVideoLink" placeholder="הדבק לינק לסרטון..." />
                <button @onclick='() => OnLinkUpdate(tempVideoLink,
                                  () => showEditVideo = false,
                                  () => Project.VideoLink = tempVideoLink)'>
                    שמור
                </button>
            </div>
            @if (showAlert)
            {
                <div class="alert alert-danger" role="alert">
                    הקישור שהזנת אינו תקין.
                </div>
            }
        }


        @* כפתור תרגול *@
        @* --- חלק התרגול --- *@
        <div class="edit-wrapper">
            <a href="@Project.ExercisesLink" target="_blank"
               class="custom-btn btn-practice @(string.IsNullOrEmpty(Project.ExercisesLink) ? "disabled" : "active")">
                <i class="bi bi-pencil-square"></i>
                <span>תרגול בגרות</span>
                @if (string.IsNullOrEmpty(Project.ExercisesLink))
                {<span class="badge">טרם הועלה</span>}
            </a>
            <button class="edit-icon-btn" @onclick="ToggleExPres">
                <i class="bi bi-pencil"></i>
            </button>
        </div>
        @if (showEditEx)
        {
            <div class="edit-box">
                <input @bind="tempExercisesLink" placeholder="הדבק לינק לתרגול..." />
                <button @onclick='() => OnLinkUpdate(tempExercisesLink,
                                  () => showEditEx = false,
                                  () => Project.ExercisesLink = tempExercisesLink)'>
                    שמור
                </button>
            </div>
            @if (showAlert)
            {
                <div class="alert alert-danger" role="alert">
                    הקישור שהזנת אינו תקין.
                </div>
            }
        }
    </div>
    @if (showSuccessMessage)
    {
        <div class="success-toast">
            <i class="oi oi-check"></i> השינויים נשמרו בהצלחה!
        </div>
    }
</div>

@code {
    [Parameter] public ProjectModel Project { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    // משתנים לשליטה על הצגת תיבות העריכה
    private bool showEditPres = false;
    private bool showEditVideo = false;
    private bool showEditEx = false;
    private bool showAlert = false;
    private bool showSuccessMessage = false;
    private string tempPresentationLink;
    private string tempVideoLink;
    private string tempExercisesLink;

    protected override void OnParametersSet()
    {
        // אתחול המשתנים הזמניים עם הערכים הנוכחיים של הפרויקט
        tempPresentationLink = Project.PresentationLink;
        tempVideoLink = Project.VideoLink;
        tempExercisesLink = Project.ExercisesLink;
    }

    private async Task SaveChanges()
    {
        // ... הקוד הקיים שלך ששומר ל-Firebase ...

        // הצגת ההודעה
        showSuccessMessage = true;
        StateHasChanged();

        // העלמת ההודעה אוטומטית אחרי 3 שניות
        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

    public bool IsComplete()
    {
        return !string.IsNullOrEmpty(Project.PresentationLink) &&
            !string.IsNullOrEmpty(Project.VideoLink) &&
            !string.IsNullOrEmpty(Project.ExercisesLink);
    }

    private async Task OpenLink(string url)
    {
        if (!IsEmptyLink(url))
        {
            // הפקודה הזו אומרת לדפדפן לפתוח חלון חדש בצורה חיצונית לחלוטין ל-Blazor
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
        }
    }

    private async Task OnLinkUpdate(string linkValue, Action closeEditBok, Action setTempLinkOnObject)
    {
        if (IsEmptyLink(linkValue))
        {
            closeEditBok();
            setTempLinkOnObject();
            await FirebaseService.UpdateProjectAsync(Project);
            await OnDataChanged.InvokeAsync(); // מעדכן את הסטטוס בר
        }
        else if (IsValidLink(linkValue))
        {
            closeEditBok();
            setTempLinkOnObject();
            await FirebaseService.UpdateProjectAsync(Project);
            await OnDataChanged.InvokeAsync(); // האיתות נשלחמעדכן את הסטטוס בר

        }
        else
        {
            showAlert = true;
        }

    }
    #region בדיקת תקינות הקישור
    private bool IsValidLink(String link)
    {
        return link.StartsWith("http://") || link.StartsWith("https://");
    }

    private bool IsEmptyLink(String link)
    {
        return string.IsNullOrEmpty(link);
    }
    #endregion

    #region טוגל של תיבות העריכה
    private void ToggleEditPres()
    {
        showEditPres = !showEditPres;
        showEditEx = false;
        showEditVideo = false;
        showAlert = false;
    }
    private void ToggleVideoPres()
    {
        showEditVideo = !showEditVideo;
        showEditPres = false;
        showEditEx = false;
        showAlert = false;
    }
    private void ToggleExPres()
    {
        showEditEx = !showEditEx;
        showEditPres = false;
        showEditVideo = false;
        showAlert = false;
    }
    #endregion
}
